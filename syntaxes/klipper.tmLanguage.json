{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Klipper",
  "scopeName": "source.klipper",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#jinja"
    },
    {
      "include": "#keys"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#gcode"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.klipper",
          "match": "#.*$"
        },
        {
          "name": "comment.line.semicolon.klipper",
          "match": ";.*$"
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "entity.name.section.klipper",
          "match": "^\\s*(\\[)([^\\]]+)(\\])",
          "captures": {
            "1": {
              "name": "punctuation.definition.section.begin.klipper"
            },
            "2": {
              "name": "entity.name.section.klipper"
            },
            "3": {
              "name": "punctuation.definition.section.end.klipper"
            }
          }
        }
      ]
    },
    "keys": {
      "patterns": [
        {
          "name": "support.type.property-name.klipper",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_\\-]*)(\\s*:)",
          "captures": {
            "1": {
              "name": "support.type.property-name.klipper"
            },
            "2": {
              "name": "punctuation.separator.key-value.klipper"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.klipper",
          "match": "(?<![A-Za-z_])[-+]?\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "gcode": {
      "patterns": [
        {
          "name": "meta.command.gcode.klipper",
          "match": "^(\\s*)([A-Z][A-Z0-9_]*|[GMT]\\d+)\\b",
          "captures": {
            "2": {
              "name": "keyword.control.gcode.klipper"
            }
          }
        },
        {
          "name": "variable.parameter.gcode.klipper",
          "match": "\\b[A-Z](?=[-+]?\\d|\\{|=)"
        },
        {
          "name": "variable.parameter.klipper",
          "match": "\\b[A-Z][A-Z0-9_]*(?=\\s*=)"
        },
        {
          "name": "keyword.control.gcode.klipper",
          "match": "\\b(?:G|M|T)\\d+\\b"
        }
      ]
    },
    "jinja": {
      "patterns": [
        {
          "name": "meta.embedded.block.jinja.klipper",
          "begin": "\\{%",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.jinja"
            }
          },
          "end": "%\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.jinja"
            }
          },
          "patterns": [
            {
              "include": "#jinja-inner"
            }
          ]
        },
        {
          "name": "meta.embedded.expression.jinja.klipper",
          "begin": "\\{\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.jinja"
            }
          },
          "end": "\\}\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.jinja"
            }
          },
          "patterns": [
            {
              "include": "#jinja-inner"
            }
          ]
        }
      ]
    },
    "jinja-inner": {
      "patterns": [
        {
          "name": "keyword.control.jinja",
          "match": "\\b(?:if|elif|else|endif|for|endfor|in|set|with|endwith|macro|endmacro|true|false|none|and|or|not|is)\\b"
        },
        {
          "name": "support.function.jinja.klipper",
          "match": "\\b(?:action_respond_info|action_raise_error|action_emergency_stop|action_call_remote_method)\\b"
        },
        {
          "name": "variable.language.klipper",
          "match": "\\b(?:printer|params|rawparams)\\b"
        },
        {
          "name": "string.quoted.double.jinja",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.jinja",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.jinja",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.jinja",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "keyword.operator.jinja",
          "match": "==|!=|<=|>=|<|>|\\+|-|\\*\\*|\\*|/|//|%|\\||~"
        },
        {
          "name": "constant.numeric.jinja",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    }
  }
}
